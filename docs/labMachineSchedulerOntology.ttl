@prefix : <https://Renzo-Henrique.github.io/labMachineSchedulerOntology#>.
@prefix gufo: <http://purl.org/nemo/gufo#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .

<https://Renzo-Henrique.github.io/labMachineSchedulerOntology> rdf:type owl:Ontology;
    owl:imports gufo:.

@base <https://Renzo-Henrique.github.io/labMachineSchedulerOntology#> .

<https://Renzo-Henrique.github.io/labMachineSchedulerOntology#> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://Renzo-Henrique.github.io/labMachineSchedulerOntology/1.0.0#> ;
                                         owl:versionInfo "1.0.0" ;
                                         dc:title "labMachineScheduler Ontology"@en ;
                                         dc:creator "Renzo Henrique Guzzo Leao";
                                         dc:source <https://github.com/Renzo-Henrique/labMachineSchedulerOntology> ;
                                         dcterms:bibliographicCitation "Renzo Henrique Guzzo Leao \"The labMachineScheduler Ontology\", 2026, https://Renzo-Henrique.github.io/labMachineSchedulerOntology"@en ;
                                         dcterms:contributor "Daniel Fernandes da Silva", "Matheus Saick de Martin", "Pedro Igor Gomes de Morais" ;
                                         dcterms:created "2026-07-12"^^xsd:date ;
                                         dcterms:modified "2026-07-12"^^xsd:date ;
                                         dcterms:language "en" ;
                                         dcterms:license <https://creativecommons.org/licenses/by/4.0/legalcode> ;
                                         vann:preferredNamespacePrefix "labMachineScheduler"@en ;
                                         vann:preferredNamespaceUri "https://Renzo-Henrique.github.io/labMachineSchedulerOntology#"^^xsd:anyURI ;
                                         rdfs:comment """The ontology represents a shared research lab environment in which computers can be registered as desktops or servers and accessed through multiple methods such as web interfaces, SSH, physical presence, or AnyDesk. It also distinguishes user roles and the scheduling of machines for use or maintenance, providing a structure for managing availability and reservation intent.
Cite this work as: 
Renzo Henrique Guzzo Leao \"The labMachineScheduler Ontology\", 2026, https://Renzo-Henrique.github.io/labMachineSchedulerOntology

This work is distributed under Creative Commons Attribution License CC BY 4.0 <https://creativecommons.org/licenses/by/4.0/legalcode>.

For the source repository, see: <https://github.com/Renzo-Henrique/labMachineSchedulerOntology>"""@en  .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/bibliographicCitation
dcterms:bibliographicCitation rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/language
dcterms:language rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .

###  http://purl.org/dc/terms/modified
dcterms:modified rdf:type owl:AnnotationProperty .

###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .

###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Classes
#################################################################
:Computer rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:FunctionalComplex;
    rdfs:label "Computer"@en, "Computador"@pt-br;
    rdfs:comment "A laboratory machine with hardware and access characteristics, such as a server or desktop, available for scheduling and management."@en, "Uma máquina de laboratório com características de hardware e acesso, como servidor ou desktop, disponível para agendamento e gerenciamento."@pt-br.
:AccessType rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:IntrinsicMode;
    rdfs:label "Access Type"@en, "Tipo de Acesso"@pt-br;
    rdfs:comment "A category representing the method through which a computer can be accessed, including web, SSH, physical, or AnyDesk."@en, "Uma categoria que representa o método pelo qual um computador pode ser acessado, incluindo web, SSH, físico ou AnyDesk."@pt-br.
:WebAccess rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Web Access"@en, "Acesso Web"@pt-br;
    rdfs:comment "An access method that uses a web interface to manage or use the computer remotely."@en, "Um método de acesso que utiliza uma interface web para gerenciar ou usar o computador remotamente."@pt-br.
:SSHAccess rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "SSH Access"@en, "Acesso SSH"@pt-br;
    rdfs:comment "An access method based on Secure Shell for remote command-line administration."@en, "Um método de acesso baseado em Secure Shell para administração remota em linha de comando."@pt-br.
:PhysicalAccess rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Physical Access"@en, "Acesso Físico"@pt-br;
    rdfs:comment "An access type representing direct physical use of the machine in the laboratory."@en, "Um tipo de acesso que representa o uso físico direto da máquina no laboratório."@pt-br.
:AnyDeskAccess rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "AnyDesk Access"@en, "Acesso AnyDesk"@pt-br;
    rdfs:comment "An access method that uses AnyDesk remote desktop software to connect to the computer."@en, "Um método de acesso que usa o software de desktop remoto AnyDesk para conectar-se ao computador."@pt-br.
:ComputerType rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:IntrinsicMode;
    rdfs:label "Computer Type"@en, "Tipo de Computador"@pt-br;
    rdfs:comment "A classifier for the general kind of computer equipment, such as servers or desktops."@en, "Um classificador para o tipo geral de equipamento de computador, como servidores ou desktops."@pt-br.
:Server rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Server"@en, "Servidor"@pt-br;
    rdfs:comment "A computer type representing laboratory servers used for centralized or shared workloads."@en, "Um tipo de computador que representa servidores de laboratório usados para cargas de trabalho centralizadas ou compartilhadas."@pt-br.
:Desktop rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Desktop"@en, "Desktop"@pt-br;
    rdfs:comment "A computer type representing workstation-style lab machines intended for individual use."@en, "Um tipo de computador que representa máquinas de laboratório em estilo workstation destinadas ao uso individual."@pt-br.
:Person rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:FunctionalComplex;
    rdfs:label "Person"@en, "Pessoa"@pt-br;
    rdfs:comment "A human being who may participate in laboratory scheduling processes."@en, "Um ser humano que pode participar dos processos de agendamento no laboratório."@pt-br.
:UserOfTheLabSchedulerSystem rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "User of the Lab Scheduler System"@en, "Usuário do sistema de Agendamento do Laboratório"@pt-br;
    rdfs:comment "A person who uses the laboratory scheduling platform, including students and professors."@en, "Uma pessoa que utiliza a plataforma de agendamento do laboratório, incluindo alunos e professores."@pt-br.
:Student rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "Student"@en, "Aluno"@pt-br;
    rdfs:comment "A lab user who participates in the system as a student, making reservations according to availability."@en, "Um usuário do laboratório que atua como aluno, realizando reservas de acordo com a disponibilidade."@pt-br.
:Professor rdf:type owl:Class, gufo:Role, owl:NamedIndividual;
    rdfs:label "Professor"@en, "Professor"@pt-br;
    rdfs:comment "A lab user who participates in the system as a professor, with permissions to manage resources and student schedules."@en, "Um usuário do laboratório que atua como professor, com permissões para gerenciar recursos e agendamentos de alunos."@pt-br.
:Permanence rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Relator;
    rdfs:label "Permanence"@en, "Permanência"@pt-br;
    rdfs:comment "A period of time during which a user is present or active in the laboratory."@en, "Um período de tempo durante o qual um usuário está presente ou ativo no laboratório."@pt-br.
:SchedulePurpose rdf:type owl:Class, gufo:AbstractIndividualType, owl:NamedIndividual;
    rdfs:subClassOf gufo:QualityValue;
    owl:equivalentClass [
  rdf:type owl:Class;
  owl:oneOf (:USE :MAINTENANCE :CANCELED)
].
:USE rdf:type :SchedulePurpose;
    rdf:label "[object Object]".
:MAINTENANCE rdf:type :SchedulePurpose;
    rdf:label "[object Object]".
:CANCELED rdf:type :SchedulePurpose;
    rdf:label "[object Object]".
:SchedulePurpose rdfs:label "Schedule Purpose"@en, "Finalidade do Agendamento"@pt-br;
    rdfs:comment "The reason why a schedule was created, such as use, maintenance, or cancellation."@en, "A razão pela qual um agendamento foi criado, como uso, manutenção ou cancelamento."@pt-br.
:Schedule rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:Relator;
    rdfs:label "Schedule"@en, "Agendamento"@pt-br;
    rdfs:comment "A reservation or maintenance interval allocated for a computer in the laboratory."@en, "Uma reserva ou intervalo de manutenção alocado para um computador no laboratório."@pt-br.
:Software rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:subClassOf gufo:FunctionalComplex;
    rdfs:label "Software"@en, "Software"@pt-br;
    rdfs:comment "A general software artifact that may be installed onto laboratory computers, including operating systems."@en, "Um artefato de software geral que pode ser instalado em computadores de laboratório, incluindo sistemas operacionais."@pt-br.
:OperatingSystem rdf:type owl:Class, gufo:SubKind, owl:NamedIndividual;
    rdfs:label "Operating System"@en, "Sistema Operacional"@pt-br;
    rdfs:comment "The system software that manages computer hardware and provides services for applications."@en, "O software de sistema que gerencia o hardware do computador e fornece serviços para aplicativos."@pt-br.
:Hardware rdf:type owl:Class, gufo:Category, owl:NamedIndividual;
    rdfs:subClassOf gufo:FunctionalComplex;
    rdfs:label "Hardware"@en, "Hardware"@pt-br;
    rdfs:comment "The physical components of a computer, including memory, storage, CPU, and GPU."@en, "Os componentes físicos de um computador, incluindo memória, armazenamento, CPU e GPU."@pt-br.
:StorageUnit rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:label "Storage Unit"@en, "Unidade de Armazenamento"@pt-br;
    rdfs:comment "A hardware component that provides persistent data storage for the computer."@en, "Um componente de hardware que fornece armazenamento persistente de dados para o computador."@pt-br.
:RandomAccessMemory rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:label "Random Access Memory"@en, "Memória de Acesso Aleatório"@pt-br;
    rdfs:comment "A hardware component used for temporary data storage while the computer is running."@en, "Um componente de hardware usado para armazenamento temporário de dados enquanto o computador está em execução."@pt-br.
:CentralProcessingUnit rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:label "Central Processing Unit"@en, "Unidade Central de Processamento"@pt-br;
    rdfs:comment "A hardware component responsible for executing instructions and processing data."@en, "Um componente de hardware responsável por executar instruções e processar dados."@pt-br.
:GraphicsProcessingUnit rdf:type owl:Class, gufo:Kind, owl:NamedIndividual;
    rdfs:label "Graphics Processing Unit"@en, "Unidade de Processamento Gráfico"@pt-br;
    rdfs:comment "A hardware component responsible for rendering graphics and accelerating visual workloads."@en, "Um componente de hardware responsável por renderizar gráficos e acelerar cargas visuais."@pt-br.
:WebAccess rdfs:subClassOf :AccessType.
:SSHAccess rdfs:subClassOf :AccessType.
:PhysicalAccess rdfs:subClassOf :AccessType.
:AnyDeskAccess rdfs:subClassOf :AccessType.
:Server rdfs:subClassOf :ComputerType.
:Desktop rdfs:subClassOf :ComputerType.
:WebAccess rdfs:subClassOf :AccessType.
:SSHAccess rdfs:subClassOf :AccessType.
:PhysicalAccess rdfs:subClassOf :AccessType.
:AnyDeskAccess rdfs:subClassOf :AccessType.
:Server rdfs:subClassOf :ComputerType.
:Desktop rdfs:subClassOf :ComputerType.
:Student rdfs:subClassOf :UserOfTheLabSchedulerSystem.
:Professor rdfs:subClassOf :UserOfTheLabSchedulerSystem.
:UserOfTheLabSchedulerSystem rdfs:subClassOf :Person.
:Student rdfs:subClassOf :UserOfTheLabSchedulerSystem.
:Professor rdfs:subClassOf :UserOfTheLabSchedulerSystem.
:StorageUnit rdfs:subClassOf :Hardware.
:RandomAccessMemory rdfs:subClassOf :Hardware.
:CentralProcessingUnit rdfs:subClassOf :Hardware.
:GraphicsProcessingUnit rdfs:subClassOf :Hardware.
:OperatingSystem rdfs:subClassOf :Software.
[ rdf:type owl:AllDisjointClasses ] owl:members (:WebAccess :SSHAccess :PhysicalAccess :AnyDeskAccess).
:AccessType owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:WebAccess :SSHAccess :PhysicalAccess :AnyDeskAccess)
].
[ rdf:type owl:AllDisjointClasses ] owl:members (:Server :Desktop).
:ComputerType owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:Server :Desktop)
].
:UserOfTheLabSchedulerSystem owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:Student :Professor)
].
[ rdf:type owl:AllDisjointClasses ] owl:members (:StorageUnit :RandomAccessMemory :CentralProcessingUnit :GraphicsProcessingUnit).
:Hardware owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:StorageUnit :RandomAccessMemory :CentralProcessingUnit :GraphicsProcessingUnit)
].
:name rdfs:domain :Computer;
    rdfs:range xsd:string;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "name"@en.
:name_1 rdfs:domain :Person;
    rdfs:range xsd:string;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "name"@en.
:email rdfs:domain :UserOfTheLabSchedulerSystem;
    rdfs:range xsd:string;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "email"@en.
:begin rdfs:domain :Permanence;
    rdfs:range xsd:dateTime;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "begin"@en.
:end rdfs:domain :Permanence;
    rdfs:range xsd:dateTime;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "end"@en.
:begin_1 rdfs:domain :Schedule;
    rdfs:range xsd:dateTime;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "begin"@en.
:end_1 rdfs:domain :Schedule;
    rdfs:range xsd:dateTime;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "end"@en.
:usePurpose rdfs:domain :Schedule;
    rdfs:range :SchedulePurpose;
    rdf:type owl:ObjectProperty;
    rdfs:subPropertyOf gufo:hasReifiedQualityValue;
    rdfs:label "usePurpose"@en.
:name_2 rdfs:domain :OperatingSystem;
    rdfs:range xsd:string;
    rdf:type owl:DatatypeProperty;
    rdfs:subPropertyOf gufo:hasQualityValue;
    rdfs:label "name"@en.
:characterizesTheAccess rdf:type owl:ObjectProperty;
    rdfs:domain :AccessType;
    rdfs:range :Computer;
    rdfs:label "characterizesTheAccess"@en;
    rdfs:subPropertyOf gufo:inheresIn.
:characterizesTheComputer rdf:type owl:ObjectProperty;
    rdfs:domain :ComputerType;
    rdfs:range :Computer;
    rdfs:label "characterizesTheComputer"@en;
    rdfs:subPropertyOf gufo:inheresIn.
:hasPermanence rdf:type owl:ObjectProperty;
    rdfs:domain :Permanence;
    rdfs:range :UserOfTheLabSchedulerSystem;
    rdfs:label "hasPermanence"@en;
    rdfs:subPropertyOf gufo:mediates.
:hasSchedule rdf:type owl:ObjectProperty;
    rdfs:domain :Schedule;
    rdfs:range :UserOfTheLabSchedulerSystem;
    rdfs:label "hasSchedule"@en;
    rdfs:subPropertyOf gufo:mediates.
:scheduledFor rdf:type owl:ObjectProperty;
    rdfs:domain :Schedule;
    rdfs:range :Computer;
    rdfs:label "scheduledFor"@en;
    rdfs:subPropertyOf gufo:mediates.
:installedOn rdf:type owl:ObjectProperty;
    rdfs:domain :OperatingSystem;
    rdfs:range :Computer;
    rdfs:label "installedOn"@en;
    rdfs:subPropertyOf gufo:isComponentOf.
:storageFor rdf:type owl:ObjectProperty;
    rdfs:domain :StorageUnit;
    rdfs:range :Computer;
    rdfs:label "storageFor"@en;
    rdfs:subPropertyOf gufo:isComponentOf.
:cpuFor rdf:type owl:ObjectProperty;
    rdfs:domain :CentralProcessingUnit;
    rdfs:range :Computer;
    rdfs:label "cpuFor"@en;
    rdfs:subPropertyOf gufo:isComponentOf.
:gpuFor rdf:type owl:ObjectProperty;
    rdfs:domain :GraphicsProcessingUnit;
    rdfs:range :Computer;
    rdfs:label "gpuFor"@en;
    rdfs:subPropertyOf gufo:isComponentOf.
:ramFor rdf:type owl:ObjectProperty;
    rdfs:domain :RandomAccessMemory;
    rdfs:range :Computer;
    rdfs:label "ramFor"@en;
    rdfs:subPropertyOf gufo:isComponentOf.